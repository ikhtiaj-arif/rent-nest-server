{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "rootDir": "./",
    "outDir": "./dist",
    "sourceMap": true,
    // "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "prisma/config": ["./node_modules/prisma/build/config.d.ts"]
    }
  },
  // "include": ["src/**/*"],
  "include": [
    "src/**/*",
    "prisma.config.ts" // <-- Add this line
  ],
  "exclude": ["dist", "node_modules"]
}
